# Postgres (Vercel Postgres / Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# OpenAI
OPENAI_API_KEY=""

# Model IDs (fixed for prod; changing embedding model requires re-embed)
EMBEDDING_MODEL="text-embedding-3-small"
CHAT_MODEL="gpt-4o-mini"

# HMAC-SHA256 storage for publishable keys (required for DB tenant auth + prisma seed)
PUBLISHABLE_KEY_PEPPER="change-me-long-random-secret"

# Retrieved chunks per chat request (default 8)
RAG_TOP_K="8"

# Optional: pgvector cosine distance gate for /api/chat. Omit or leave unset to disable filtering.
# Lower distance = more similar. Typical starting values: 0.30–0.45 (tune using retrieval logs).
# When set: chunks above this distance are dropped; if all top-K are dropped, the API returns a
# fixed “not in indexed content” message instead of calling the chat model.
# RAG_MAX_COSINE_DISTANCE="0.35"

# Protects internal ingest triggers; Vercel Cron can use CRON_SECRET (Bearer) from the dashboard
INGEST_CRON_SECRET=""
CRON_SECRET=""

# Admin dashboard: signed session cookie + login (set strong values in production)
ADMIN_SECRET=""
ADMIN_DASHBOARD_USER=""
ADMIN_DASHBOARD_PASSWORD=""
# Optional: same value as seeded demo publishable key so admin can copy embed for demo-site without rotating
ADMIN_DEMO_PUBLISHABLE_KEY=""
