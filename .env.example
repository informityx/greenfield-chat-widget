# Protects internal ingest triggers; Vercel Cron can use CRON_SECRET (Bearer) from the dashboard
INGEST_CRON_SECRET=""
CRON_SECRET=""

# Bootstrap admin routes (replace with proper auth later)
ADMIN_SECRET=""
